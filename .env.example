# Firebase Configuration — Copy to .env and fill in your values
# DO NOT commit .env to version control
FIREBASE_API_KEY_WEB=
FIREBASE_API_KEY_ANDROID=
FIREBASE_API_KEY_IOS=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID_WEB=
FIREBASE_APP_ID_ANDROID=
FIREBASE_APP_ID_IOS=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_AUTH_DOMAIN=
FIREBASE_MEASUREMENT_ID=

# Asaas Payment Gateway
# Obtido em: Painel Asaas → Minha Conta → Integrações → Chave de API
ASAAS_API_KEY=
# Produção:   https://api.asaas.com/v3
# Sandbox:    https://sandbox.asaas.com/api/v3
ASAAS_BASE_URL=https://api.asaas.com/v3
# Token para validar os eventos de webhook (configure no painel Asaas)
ASAAS_WEBHOOK_TOKEN=

# App Check (Web) — chave reCAPTCHA v3.
# Gere em: Firebase Console → App Check → Apps → Web → reCAPTCHA v3.
# DEIXE VAZIO até ter a chave real: sem ela, o App Check no web é PULADO
# (se preenchida com chave inválida, quebra auth/Firestore/Functions no web).
RECAPTCHA_V3_SITE_KEY=
