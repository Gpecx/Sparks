rules_version = '2';

// Endurecimento de segurança pré-lançamento (2026-06-10):
// - orders: leitura restrita ao dono;
// - rankings: escrita só via Cloud Functions (Admin SDK);
// - clãs: bloqueio de auto-promoção a admin e de autoria forjada.

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Funções auxiliares ───────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isSelf(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isClanMember(clanId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/clans/$(clanId)/members/$(request.auth.uid));
    }

    function isClanAdmin(clanId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/clans/$(clanId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/clans/$(clanId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    function isClanModerator(clanId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/clans/$(clanId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/clans/$(clanId)/members/$(request.auth.uid)).data.role == 'moderador';
    }

    function isClanAdminOrModerator(clanId) {
      return isClanAdmin(clanId) || isClanModerator(clanId);
    }

    // Campos controlados exclusivamente pelo servidor (Cloud Functions / Admin SDK).
    // Qualquer escrita do cliente que toque um destes campos é BLOQUEADA — somente
    // o Admin SDK (que ignora as regras) pode alterá-los. Isso garante que a economia
    // (XP, ELO) e o status de assinatura/pagamento não sejam adulterados.
    function touchesServerControlledFields() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasAny([
          'xp',
          'level',
          'tensionLevel',
          'eloRating',
          'wins',
          'losses',
          'totalDuels',
          'weeklyXp',
          'monthlyXp',
          // ── Assinatura / Pagamento (somente Cloud Functions) ──
          'isPremium',
          'isOnTrial',
          'hadTrial',
          'trialEndsAt',
          'subscriptionPlanId',
          'trialCardTokenId',
          'asaasCustomerId',
          // ── Acesso-cortesia via código (somente Cloud Functions) ──
          'compAccessExpiresAt',
          'compAccessSource',
          'compAccessCode'
        ]);
    }

    // ─── USERS ───────────────────────────────────────────────────

    match /users/{uid} {
      // LGPD: o documento do usuário contém dados pessoais (email, dados de
      // assinatura, tokens de pagamento). Só o próprio usuário e admins leem.
      // Dados públicos (nome, foto, xp, nível, clã) ficam em /public_profiles.
      allow read: if isSelf(uid) || isAdmin();
      // Na criação, o usuário não pode "nascer" com saldo/benefícios arbitrários:
      // os valores iniciais são FIXOS (papel padrão, XP 0, ELO base). Premium/trial
      // nunca podem vir ativos. Qualquer aumento posterior só é concedido via
      // Cloud Functions (Admin SDK).
      allow create: if isSelf(uid)
        && request.resource.data.keys().hasAll(['uid', 'email', 'role'])
        && request.resource.data.role == 'técnico'
        && request.resource.data.xp == 0
        && (!('eloRating' in request.resource.data) || request.resource.data.eloRating == 1200)
        && (!('isPremium' in request.resource.data) || request.resource.data.isPremium == false)
        && (!('isOnTrial' in request.resource.data) || request.resource.data.isOnTrial == false)
        && (!('hadTrial' in request.resource.data) || request.resource.data.hadTrial == false);
      // Update do próprio usuário: pode editar perfil (nome, foto, streak, etc.),
      // mas NUNCA campos controlados pelo servidor (economia/assinatura) nem 'role'.
      allow update: if (isSelf(uid)
          && !('role' in request.resource.data.diff(resource.data).affectedKeys())
          && !touchesServerControlledFields())
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clanId', 'clanName'])
          && (
              isSelf(uid)
              || !('clanId' in resource.data)
              || resource.data.clanId == ""
              || (('clanId' in resource.data) && resource.data.clanId != "" && (isClanAdminOrModerator(resource.data.clanId) || get(/databases/$(database)/documents/clans/$(resource.data.clanId)).data.createdBy == request.auth.uid))
              || (('clanId' in request.resource.data) && request.resource.data.clanId != "" && (isClanAdminOrModerator(request.resource.data.clanId) || get(/databases/$(database)/documents/clans/$(request.resource.data.clanId)).data.createdBy == request.auth.uid))
          )
        );
      allow write: if isAdmin();

      match /progress/{modId} {
        allow read: if isSelf(uid);
        allow write: if isSelf(uid)
          && (!request.resource.data.keys().hasAny(['progressPercent'])
             || request.resource.data.progressPercent is number)
          && (!request.resource.data.keys().hasAny(['bestScore'])
             || request.resource.data.bestScore is number);
      }

      match /covenants/{covId} {
        allow read: if isSelf(uid);
        allow write: if isSelf(uid)
          && (!request.resource.data.keys().hasAny(['currentProgress'])
             || request.resource.data.currentProgress is number);
      }

      match /quiz_history/{id} {
        allow read, write: if isSelf(uid);
      }

      match /ebook_progress/{ebookId} {
        allow read, write: if isSelf(uid);
      }

      match /transactions/{txId} {
        allow read: if isSelf(uid);
        allow write: if false;
      }

      match /audit_log/{logId} {
        allow read: if isSelf(uid);
        allow write: if isAdmin();
      }

      match /notifications/{notifId} {
        allow read: if isSelf(uid);
        allow update: if isSelf(uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);
        allow create, delete: if isAdmin();
      }

      match /missions/{missionId} {
        allow read: if isSelf(uid);
        allow write: if isSelf(uid);
      }
    }

    // ─── PUBLIC PROFILES ──────────────────────────────────────────
    // Espelho somente-leitura com APENAS campos públicos (nome, foto, xp,
    // nível, clã). Mantido pela Cloud Function syncPublicProfile. Nenhum
    // dado pessoal sensível trafega aqui. Escrita exclusiva do servidor.

    match /public_profiles/{uid} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ─── CATEGORIES / MODULES / TRAILS / LESSONS / QUESTIONS ─────
    // IMPORTANTE: Hierarquia correta é categories → modules → trails → lessons → questions
    // A subcoleção 'trails' estava AUSENTE nas regras anteriores, causando falha silenciosa
    // nas escritas e leituras de trilhas, lições e questões.

    match /categories/{catId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();

      match /modules/{modId} {
        allow read: if isAuthenticated();
        allow update: if isAdmin() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['accessCount']));
        allow create, delete: if isAdmin();

        match /trails/{trailId} {
          allow read: if isAuthenticated();
          allow write: if isAdmin();

          match /lessons/{lessonId} {
            allow read: if isAuthenticated();
            allow write: if isAdmin();

            match /questions/{questionId} {
              allow read: if isAuthenticated();
              allow write: if isAdmin();
            }
          }
        }

        // ── E-books (área de Estudos) ─────────────────────────────
        match /ebooks/{ebookId} {
          allow read: if isAuthenticated();
          allow write: if isAdmin();

          // Capítulos do e-book (conteúdo carregado sob demanda)
          match /chapters/{chapterId} {
            allow read: if isAuthenticated();
            allow write: if isAdmin();
          }
        }
      }
    }

    // ─── CLANS ────────────────────────────────────────────────────

    match /clans/{clanId} {
      allow read: if isAuthenticated();
      // O criador deve ser sempre o próprio chamador (impede forjar dono).
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      // Só admin/moderador/dono podem reescrever o doc do clã.
      // Membros comuns só podem mexer no contador (memberCount) ao entrar/sair.
      allow update: if isClanAdminOrModerator(clanId)
        || resource.data.createdBy == request.auth.uid
        || isAdmin()
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount']) && isAuthenticated());
      allow delete: if resource.data.createdBy == request.auth.uid || isClanAdmin(clanId) || isAdmin();

      match /members/{memberUid} {
        allow read: if isAuthenticated();
        // Auto-cadastro só é permitido como 'membro'. Papéis elevados
        // (admin/moderador) só por admin/mod existente ou pelo dono do clã.
        allow create: if isClanAdminOrModerator(clanId)
          || isAdmin()
          || get(/databases/$(database)/documents/clans/$(clanId)).data.createdBy == request.auth.uid
          || (request.auth.uid == memberUid && request.resource.data.role == 'membro');
        // O próprio membro pode editar seu doc, MAS nunca o campo 'role'
        // (impede auto-promoção a admin/moderador do clã).
        allow update: if (request.auth.uid == memberUid
            && !('role' in request.resource.data.diff(resource.data).affectedKeys()))
          || isClanAdminOrModerator(clanId)
          || isAdmin()
          || get(/databases/$(database)/documents/clans/$(clanId)).data.createdBy == request.auth.uid;
        allow delete: if request.auth.uid == memberUid
          || isAdmin()
          || (exists(/databases/$(database)/documents/clans/$(clanId))
              && (isClanAdminOrModerator(clanId)
                  || get(/databases/$(database)/documents/clans/$(clanId)).data.createdBy == request.auth.uid));
      }

      match /messages/{id} {
        // Só membros postam, e o autor (uid) precisa ser o próprio chamador
        // (impede mensagens com autoria forjada).
        allow create: if isClanMember(clanId)
          && request.resource.data.uid == request.auth.uid;
        allow read: if isClanMember(clanId);
        allow update: if false;
        allow delete: if resource.data.uid == request.auth.uid
          || isClanAdminOrModerator(clanId)
          || isAdmin()
          || get(/databases/$(database)/documents/clans/$(clanId)).data.createdBy == request.auth.uid;
      }

      match /leagueProgress/{progressId} {
        allow read: if isAuthenticated();
        allow write: if isClanAdminOrModerator(clanId) || isAdmin();
      }

      match /weeklyMissions/{missionId} {
        allow read: if isAuthenticated();
        allow write: if isClanAdminOrModerator(clanId) || isAdmin();
      }

      match /quests/{questId} {
        allow read: if isAuthenticated();
        allow write: if isClanAdminOrModerator(clanId)
          || isAdmin()
          || get(/databases/$(database)/documents/clans/$(clanId)).data.createdBy == request.auth.uid;
      }

      match /requests/{requestId} {
        allow read: if isClanAdminOrModerator(clanId) || isAdmin() || get(/databases/$(database)/documents/clans/$(clanId)).data.createdBy == request.auth.uid;
        allow create: if isAuthenticated() && request.auth.uid == requestId;
        allow update: if isClanAdminOrModerator(clanId) || isAdmin() || request.auth.uid == requestId;
        allow delete: if isClanAdminOrModerator(clanId) || isAdmin() || request.auth.uid == requestId;
      }
    }

    // ─── RANKINGS ─────────────────────────────────────────────────

    match /rankings/{id} {
      allow read: if isAuthenticated();
      allow write: if false;

      match /{weekKey}/{uid} {
        allow read: if isAuthenticated();
        // Pontuação do ranking é escrita SOMENTE pelas Cloud Functions
        // (Admin SDK ignora estas regras). Cliente não pode forjar score.
        allow write: if false;
      }
    }

    // ─── MATCHES (DUELOS) ─────────────────────────────────────────

    match /matches/{matchId} {
      // Os dois participantes LEEM o duelo (para sincronizar em tempo real).
      allow read: if isAuthenticated()
        && (resource.data.player1Uid == request.auth.uid
           || resource.data.player2Uid == request.auth.uid);
      // Criação/escrita/apuração são EXCLUSIVAS das Cloud Functions
      // (Admin SDK ignora estas regras). Impede forjar partidas, placares
      // ou resultado de ELO pelo cliente.
      allow create, update, delete: if false;

      // Gabarito do duelo — NUNCA legível pelo cliente (só a CF, via Admin SDK).
      match /secret/{docId} {
        allow read, write: if false;
      }
    }

    match /matchmaking_queue/{uid} {
      // O jogador só LÊ o próprio doc da fila (para detectar o matchId que a
      // Cloud Function grava ao parear). Entrada/saída da fila e pareamento
      // são feitos pelas CFs joinDuelQueue/leaveDuelQueue (Admin SDK).
      allow read: if request.auth.uid == uid;
      allow write: if false;
    }

    // ─── LOJA / BADGES / EVENTOS ──────────────────────────────────

    match /store_items/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /badges/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /active_events/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── STANDARDS METADATA ───────────────────────────────────────

    match /standards_metadata/{stdId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data)
             .affectedKeys().hasOnly(['clickCount']);
      allow create, delete: if isAdmin();
    }

    // ─── TRANSACTIONS (legado raiz — somente leitura) ─────────────

    match /transactions/{id} {
      allow read: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // ─── VOUCHERS / CÓDIGOS DE ACESSO ─────────────────────────────

    // access_codes: totalmente fechado ao cliente — criação, resgate e
    // revogação acontecem só via Cloud Functions (Admin SDK ignora as regras).
    match /access_codes/{code} {
      allow read, write: if false;
    }

    // voucher_redemptions: auditoria de resgates. O dono lê o seu histórico;
    // a escrita é exclusiva da Cloud Function redeemAccessCode (Admin SDK).
    match /voucher_redemptions/{id} {
      allow read: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // ─── PEDIDOS (ORDERS) ─────────────────────────────────────────
    // O dono do pedido pode ler o status (necessário para o listener
    // do PaymentPendingScreen detectar a confirmação do pagamento).
    // Escrita exclusiva via Cloud Functions (Admin SDK — ignora regras).

    match /orders/{orderId} {
      // Apenas o DONO do pedido pode ler (evita vazamento de dados de
      // pagamento/PII entre usuários). Escrita só via Cloud Functions.
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // ─── SUPORTE ──────────────────────────────────────────────────

    match /support_tickets/{ticketId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // ─── PLANOS: Verificação de estudante (PDF §8) ────────────────
    match /student_verifications/{uid} {
      // Dono lê o próprio status; admin lê tudo.
      allow read: if isSelf(uid) || isAdmin();
      // O dono só pode submeter/atualizar com status 'pending'. A
      // aprovação/rejeição (status 'approved'/'rejected') é exclusiva
      // do admin/Cloud Function — impede auto-aprovação fraudulenta.
      allow create, update: if isSelf(uid)
        && request.resource.data.status == 'pending';
      allow write: if isAdmin();
    }

    // ─── BUSINESS: leads comerciais (PDF §9) ──────────────────────
    match /business_leads/{leadId} {
      // Qualquer autenticado pode solicitar proposta; gestão é do admin.
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // ─── BUSINESS: organizações (PDF §3) ──────────────────────────
    match /organizations/{orgId} {
      // Dono e membros (por uid) podem ler.
      allow read: if isAuthenticated()
        && (resource.data.ownerUid == request.auth.uid
            || request.auth.uid in resource.data.get('memberUids', []));
      // O dono gerencia membros (convidar/remover). Criação e campos
      // sensíveis (seats/plano/assinatura) ficam a cargo da Cloud
      // Function do fluxo de pagamento.
      allow update: if isAuthenticated()
        && resource.data.ownerUid == request.auth.uid;
      allow create, delete: if isAdmin();
    }
  }
}
