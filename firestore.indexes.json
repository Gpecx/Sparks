{
  // Índices compostos versionados (antes este arquivo estava vazio, fazendo
  // queries com filtro + ordenação/desigualdade falharem com FAILED_PRECONDITION
  // em qualquer ambiente novo ou re-deploy).
  "indexes": [
    {
      // verifyEmailCode: OTP mais recente do usuário (caminho crítico de login).
      // db.collection('_email_otps').where('uid','==',uid).orderBy('createdAt','desc')
      "collectionGroup": "_email_otps",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "uid", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      // processTrialExpiry: trials ativos vencidos.
      // db.collection('users').where('isOnTrial','==',true).where('trialEndsAt','<=',now)
      "collectionGroup": "users",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isOnTrial", "order": "ASCENDING" },
        { "fieldPath": "trialEndsAt", "order": "ASCENDING" }
      ]
    },
    {
      // Painel de suporte do admin: filtra por categoria e ordena por data.
      // collection('support_tickets').where('category','==',cat).orderBy('createdAt','desc')
      "collectionGroup": "support_tickets",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "category", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      // Histórico de duelos (como player1): partidas encerradas, mais recentes.
      // matches.where('player1Uid','==',uid).where('status','==','finished').orderBy('finishedAt','desc')
      "collectionGroup": "matches",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "player1Uid", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "finishedAt", "order": "DESCENDING" }
      ]
    },
    {
      // Histórico de duelos (como player2): partidas encerradas, mais recentes.
      // matches.where('player2Uid','==',uid).where('status','==','finished').orderBy('finishedAt','desc')
      "collectionGroup": "matches",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "player2Uid", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "finishedAt", "order": "DESCENDING" }
      ]
    }
  ],
  "fieldOverrides": []
}
