{
  // Índices compostos versionados (antes este arquivo estava vazio, fazendo
  // queries com filtro + ordenação/desigualdade falharem com FAILED_PRECONDITION
  // em qualquer ambiente novo ou re-deploy).
  "indexes": [
    {
      // verifyEmailCode: OTP mais recente do usuário (caminho crítico de login).
      // db.collection('_email_otps').where('uid','==',uid).orderBy('createdAt','desc')
      "collectionGroup": "_email_otps",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "uid", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      // processTrialExpiry: trials ativos vencidos.
      // db.collection('users').where('isOnTrial','==',true).where('trialEndsAt','<=',now)
      "collectionGroup": "users",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isOnTrial", "order": "ASCENDING" },
        { "fieldPath": "trialEndsAt", "order": "ASCENDING" }
      ]
    }
  ],
  "fieldOverrides": []
}
